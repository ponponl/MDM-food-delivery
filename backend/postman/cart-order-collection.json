  "item": [
    {
      "name": "Cart Management",
      "item": [
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userExternalId\": \"test_user_001\",\n  \"itemId\": \"12\",\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/cart/items",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "cart", "items"]
            }
          }
        },
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/cart?userExternalId=test_user_001",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "cart"],
              "query": [
                {
                  "key": "userExternalId",
                  "value": "test_user_001"
                }
              ]
            }
          }
        },
        {
          "name": "Update Item Quantity",
          "request": {
