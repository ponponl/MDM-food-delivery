    {
      "name": "Order Management",
      "item": [
        {
          "name": "Create Order (Checkout)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userExternalId\": \"test_user_001\",\n  \"restaurantId\": \"res_22\",\n  \"deliveryAddress\": {\n    \"receiver\": \"Nguyen Van A\",\n    \"phone\": \"0909123456\",\n    \"address\": \"123 Nguyen Van Cu, Quan 5, TP.HCM\"\n  },\n  \"note\": \"Không hành\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "Get Order Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/orders/:orderExternalId",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "orders", ":orderExternalId"],
              "variable": [
                {
                  "key": "orderExternalId",
                  "value": "replace-with-actual-uuid"
                }
              ]
            }
          }
        },
        {
          "name": "Get User Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/orders?userExternalId=test_user_001&limit=10&offset=0",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "orders"],
              "query": [
                {
                  "key": "userExternalId",
                  "value": "test_user_001"
                },
                {
                  "key": "status",
                  "value": "placed",
                  "disabled": true
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Order Status Updates",
      "item": [
        {
          "name": "Confirm Order",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estimatedPrepTime\": 20\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/orders/:orderExternalId/confirm",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "orders", ":orderExternalId", "confirm"],
              "variable": [
                {
                  "key": "orderExternalId",
                  "value": "replace-with-actual-uuid"
                }
              ]
            }
          }
        },
        {
          "name": "Start Delivery",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"driverId\": \"driver_123\",\n  \"estimatedDeliveryTime\": 25\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/orders/:orderExternalId/deliver",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "orders", ":orderExternalId", "deliver"],
              "variable": [
                {
                  "key": "orderExternalId",
                  "value": "replace-with-actual-uuid"
                }
              ]
            }
          }
        },
        {
          "name": "Complete Order",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"completedBy\": \"driver\",\n  \"signature\": \"base64_string_here\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/orders/:orderExternalId/complete",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "orders", ":orderExternalId", "complete"],
              "variable": [
                {
                  "key": "orderExternalId",
                  "value": "replace-with-actual-uuid"
                }
              ]
            }
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Customer requested cancellation\",\n  \"cancelledBy\": \"user\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/orders/:orderExternalId/cancel",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "orders", ":orderExternalId", "cancel"],
              "variable": [
                {
                  "key": "orderExternalId",
                  "value": "replace-with-actual-uuid"
                }
              ]
            }
          }
        }
      ]
    },
